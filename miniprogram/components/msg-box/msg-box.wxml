<!--components/msg-box/msg-box.wxml-->
<view class="msg-box-container">
  <movable-area class="movable-area">
    <movable-view class="floating-btn {{(isSyncing || isDragging) ? 'no-transition' : ''}}" 
      direction="all" 
      x="{{btnX}}" y="{{btnY}}" 
      animation="{{useAnimation}}"
      bindchange="onBtnMove" 
      bindtap="toggleMsgBox" 
      bindtouchstart="onTouchStart"
      bindtouchend="onTouchEnd"
      inertia="{{true}}"
      out-of-bounds="{{true}}"
      damping="{{40}}"
      friction="{{2}}">
      <view class="msg-icon-wrapper">
        <text class="msg-icon">✉️</text>
        <view class="msg-dot" wx:if="{{hasNewMsg}}"></view>
      </view>
    </movable-view>
  </movable-area>

  <!-- 全屏消息中心 (Premium 版) -->
  <view class="msg-overlay {{showMsgBox ? 'show' : ''}} {{msgBoxAnimateClass}}" style="--circle-x: {{clickX}}px; --circle-y: {{clickY}}px;">
    <view class="msg-header {{customNav ? 'is-custom-nav' : ''}}">
      <view class="header-left">
        <text class="msg-title">消息中心</text>
        <text class="msg-subtitle">您的校园智慧助手</text>
      </view>
      <view class="btn-close-msg" bindtap="toggleMsgBox">✕</view>
    </view>

    <scroll-view scroll-y class="msg-content-scroll">
      <!-- 1. 下一节课卡片 -->
      <view class="msg-section">
        <text class="section-label">今日焦点</text>
        <view class="msg-card next-course-card {{nextCourse ? '' : 'is-empty'}}">
          <block wx:if="{{nextCourse}}">
            <text class="card-status-label">NEXT LESSON</text>
            <text class="course-large-name">{{nextCourse.course_name}}</text>
            <view class="course-meta-row">
              <view class="meta-item"><text class="meta-icon">🕒</text><text>{{nextCourse.startTime}}</text></view>
              <view class="meta-item"><text class="meta-icon">📍</text><text>{{nextCourse.location}}</text></view>
            </view>
            <view class="countdown-tag">
              <text class="upcoming-icon" wx:if="{{nextCourse.isUpcoming}}">🔔</text>
              <text>{{nextCourse.countdown}} 上课</text>
            </view>
          </block>
          <block wx:elif="{{!hasSchedule}}">
            <text class="empty-msg">尚未上传课表 📤</text>
          </block>
          <block wx:elif="{{isTodayFree}}">
            <text class="empty-msg">今日无课，尽情享受吧 ☕️</text>
          </block>
          <block wx:else>
            <text class="empty-msg">今日课程已全部结束 🍻</text>
          </block>
        </view>
      </view>

      <!-- 2. 校园公共事件 (轮播显示) -->
      <view class="msg-section" wx:if="{{publicEvents.length > 0}}">
        <text class="section-label">校园动态</text>
        <view class="public-event-card">
          <view class="event-indicator">
            <view class="dot {{index === currentEventIndex ? 'active' : ''}}" wx:for="{{publicEvents}}" wx:key="index"></view>
          </view>
          <view class="event-body" wx:if="{{currentEvent}}">
            <text class="event-title">{{currentEvent.title}}</text>
            <text class="event-desc">{{currentEvent.content}}</text>
            <view class="event-footer">
              <text class="event-date">📅 {{currentEvent.date_formatted}}</text>
              <text class="event-loc">📍 {{currentEvent.location}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 3. 系统通知 -->
      <view class="msg-section">
        <text class="section-label">通知列表</text>
        <view class="notification-item" wx:for="{{notifications}}" wx:key="id">
          <view class="noti-icon">{{item.icon}}</view>
          <view class="noti-body">
            <text class="noti-title">{{item.title}}</text>
            <text class="noti-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
