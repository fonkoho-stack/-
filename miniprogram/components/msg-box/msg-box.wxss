/* components/msg-box/msg-box.wxss */
.msg-box-container {
  display: block;
  --bg-fog: rgba(242, 242, 247, 0.85); /* iOS System Gray 6 (Alpha) */
  --polar-gray: #E5E5EA; /* iOS System Gray 5 */
  --card-shadow: 0 16rpx 48rpx rgba(0,0,0,0.08);
}

.movable-area {
  position: fixed;
  top: 0; left: 0;
  width: 100vw; height: 100vh;
  pointer-events: none;
  z-index: 9999;
}

.floating-btn {
  width: 110rpx; height: 110rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  pointer-events: auto;
}

.no-transition { transition: none !important; }

.msg-icon-wrapper { position: relative; }
.msg-icon { font-size: 54rpx; filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.1)); }
.msg-dot {
  position: absolute;
  top: 4rpx; right: 4rpx;
  width: 18rpx; height: 18rpx;
  background: #ff4757;
  border-radius: 50%;
  border: 3rpx solid #fff;
  box-shadow: 0 2rpx 6rpx rgba(255, 71, 87, 0.4);
}

/* Overlay - Premium Design */
.msg-overlay {
  position: fixed;
  top: 0; left: 0;
  width: 100vw; height: 100vh;
  background: var(--bg-fog);
  backdrop-filter: blur(20px);
  z-index: 10000;
  display: flex;
  flex-direction: column;
  visibility: hidden;
  opacity: 0;
  padding: 40rpx;
  box-sizing: border-box;
  will-change: clip-path, opacity; /* 开启 GPU 加速，优化 Backdrop-filter 性能 */
}

.msg-overlay.show { 
  /* 移除全局 transition，一切交给水波纹关键帧处理，避免状态竞争 */
  visibility: visible; 
  opacity: 1; 
}

.msg-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: calc(env(safe-area-inset-top) + 20rpx);
  margin-bottom: 60rpx;
}

.msg-header.is-custom-nav {
  margin-top: calc(env(safe-area-inset-top) + 110rpx);
}

.header-left { display: flex; flex-direction: column; }
.msg-title { font-size: 60rpx; font-weight: 800; color: var(--text-main); letter-spacing: -2rpx; }
.msg-subtitle { font-size: 24rpx; color: var(--text-sub); font-weight: 500; margin-top: 4rpx; }

.btn-close-msg {
  width: 80rpx; height: 80rpx;
  background: var(--polar-gray);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--text-sub);
}

.msg-content-scroll { flex: 1; height: 0; }

.msg-section { margin-bottom: 50rpx; }
.section-label {
  font-size: 20rpx;
  font-weight: 800;
  color: var(--text-sub);
  letter-spacing: 4rpx;
  text-transform: uppercase;
  margin-bottom: 24rpx;
  display: block;
}

/* Cards */
.msg-card {
  background: #fff;
  border-radius: 40rpx;
  padding: 44rpx;
  box-shadow: var(--card-shadow);
  border: 1rpx solid rgba(0,0,0,0.02);
}

.next-course-card {
  background: linear-gradient(135deg, var(--brand-green), #2ecc71);
  color: #fff;
}

.next-course-card.is-empty {
  background: #fff;
  color: var(--text-sub);
  text-align: center;
  padding: 80rpx 44rpx;
}

.card-status-label { font-size: 20rpx; font-weight: 800; opacity: 0.8; letter-spacing: 2rpx; margin-bottom: 12rpx; display: block; }
.course-large-name { font-size: 48rpx; font-weight: 800; line-height: 1.2; margin-bottom: 30rpx; display: block; }
.course-meta-row { display: flex; gap: 30rpx; margin-bottom: 30rpx; }
.meta-item { display: flex; align-items: center; font-size: 26rpx; opacity: 0.9; font-weight: 500; }
.meta-icon { margin-right: 10rpx; }

.countdown-tag {
  background: rgba(255,255,255,0.25);
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 800;
  display: inline-block;
}

/* Public Event Card */
.public-event-card {
  background: #fff;
  border-radius: 40rpx;
  padding: 40rpx;
  box-shadow: var(--card-shadow);
  position: relative;
  overflow: hidden;
}

.event-indicator { position: absolute; right: 40rpx; top: 40rpx; display: flex; gap: 8rpx; }
.dot { width: 8rpx; height: 8rpx; background: var(--polar-gray); border-radius: 50%; transition: all 0.3s; }
.dot.active { width: 30rpx; background: var(--brand-green); border-radius: 4rpx; }

.event-title { font-size: 34rpx; font-weight: 700; color: var(--text-main); display: block; margin-bottom: 16rpx; }
.event-desc { font-size: 26rpx; color: var(--text-sub); line-height: 1.6; display: block; margin-bottom: 30rpx; }
.event-footer { display: flex; gap: 30rpx; border-top: 1rpx solid var(--polar-gray); padding-top: 24rpx; }
.event-date, .event-loc { font-size: 22rpx; color: var(--text-sub); font-weight: 500; }

/* Notifications */
.notification-item {
  background: #fff;
  border-radius: 32rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.noti-icon { font-size: 40rpx; margin-right: 24rpx; width: 80rpx; height: 80rpx; background: var(--bg-fog); border-radius: 20rpx; display: flex; align-items: center; justify-content: center; }
.noti-body { flex: 1; }
.noti-title { font-size: 28rpx; font-weight: 700; color: var(--text-main); display: block; }
.noti-desc { font-size: 22rpx; color: var(--text-sub); margin-top: 4rpx; display: block; }

/* Water Ripple Animation (Fixed Flickering & Reliability) */
@keyframes waterRippleIn {
  0% { 
    clip-path: circle(0% at var(--circle-x) var(--circle-y));
    opacity: 0;
  }
  20% { opacity: 1; }
  100% { 
    clip-path: circle(150% at var(--circle-x) var(--circle-y));
    opacity: 1;
  }
}

@keyframes waterRippleOut {
  0% { 
    clip-path: circle(150% at var(--circle-x) var(--circle-y));
    opacity: 1;
  }
  80% { opacity: 1; }
  100% { 
    clip-path: circle(0% at var(--circle-x) var(--circle-y));
    opacity: 0;
  }
}

.animate-ripple { 
  animation: waterRippleIn 0.8s cubic-bezier(0.19, 1, 0.22, 1) forwards; 
}

.animate-ripple-out { 
  animation: waterRippleOut 0.8s cubic-bezier(0.19, 1, 0.22, 1) forwards; 
}

.upcoming-icon {
  margin-right: 8rpx;
  animation: pulse-ring 2s infinite;
  display: inline-block;
  color: #FF9500; /* iOS Warning Orange */
}

@keyframes pulse-ring {
  0% { transform: scale(0.9); opacity: 0.7; }
  50% { transform: scale(1.2); opacity: 1; }
  100% { transform: scale(0.9); opacity: 0.7; }
}
