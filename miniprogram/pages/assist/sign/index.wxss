.page {
  min-height: 100vh;
  background: #f8f9fa;
  padding: 32rpx;
  box-sizing: border-box;
}

.hero {
  background: linear-gradient(135deg, #f97316 0%, #ef4444 100%);
  color: #fff;
  border-radius: 32rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 16rpx 36rpx rgba(239, 68, 68, 0.18);
}

.hero-tag {
  display: inline-block;
  font-size: 22rpx;
  background: rgba(255, 255, 255, 0.16);
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  margin-bottom: 18rpx;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 800;
  margin-bottom: 14rpx;
}

.hero-desc {
  font-size: 26rpx;
  line-height: 1.7;
  opacity: 0.94;
}

.loading-block {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  color: #666;
}

.spinner {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 6rpx solid #f2ddd9;
  border-top-color: #ef4444;
  animation: spin 0.9s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.card {
  margin-top: 28rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #202124;
}

.status-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 22rpx;
}

.pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.pill.done {
  background: #eaf7ef;
  color: #2f8e49;
}

.pill.pending {
  background: #fff1e9;
  color: #d6632f;
}

.pill.ghost {
  background: #f3f4f6;
  color: #5f6570;
}

.tip {
  margin-top: 22rpx;
  background: #faf6ef;
  color: #8f612e;
  border-radius: 20rpx;
  padding: 20rpx 22rpx;
  font-size: 25rpx;
  line-height: 1.7;
}

.detail-line {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.7;
}

.photo-box {
  margin-top: 22rpx;
  border-radius: 20rpx;
  background: #f5f7f8;
  padding: 20rpx 22rpx;
}

.photo-box.empty {
  color: #7b8086;
  font-size: 24rpx;
}

.photo-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #202124;
}

.photo-time {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7b8086;
}

.button-row {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.input {
  width: 100%;
  box-sizing: border-box;
  min-height: 90rpx;
  border-radius: 20rpx;
  background: #f7f8fa;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #222;
  margin-top: 22rpx;
}

button {
  border: none;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
}

button::after {
  border: none;
}

.primary {
  background: #ef4444;
  color: #fff;
}

.secondary {
  background: #fff1ea;
  color: #d6632f;
}

.full {
  margin-top: 24rpx;
}
