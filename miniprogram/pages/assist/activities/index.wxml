<view class="page">
  <view class="hero">
    <view class="hero-tag">课程活动</view>
    <view class="hero-title">{{courseName}}</view>
    <view class="hero-desc">一期只接入签到主链路。签到类活动会提供直接入口，其它活动仍会展示，但会明确标记是否支持。</view>
  </view>

  <view class="loading-block" wx:if="{{loading}}">
    <view class="spinner"></view>
    <text>正在拉取活动...</text>
  </view>

  <view class="empty-card" wx:elif="{{errorText}}">
    <view class="empty-title">加载失败</view>
    <view class="empty-desc">{{errorText}}</view>
    <button class="primary" bindtap="loadActivities">重新加载</button>
  </view>

  <view class="empty-card" wx:elif="{{!activities.length}}">
    <view class="empty-title">暂无活动</view>
    <view class="empty-desc">这门课当前没有可展示的活动，或者超星接口暂时没有返回数据。</view>
  </view>

  <view class="activity-list" wx:else>
    <view class="activity-card" wx:for="{{activities}}" wx:key="id">
      <view class="top-row">
        <view class="title-wrap">
          <view class="name">{{item.name}}</view>
          <view class="desc" wx:if="{{item.description}}">{{item.description}}</view>
        </view>
        <view class="status {{item.status ? 'active' : 'inactive'}}">{{item.statusText}}</view>
      </view>

      <view class="meta-row">
        <view class="tag">{{item.activeTypeLabel || '活动'}}</view>
        <view class="tag sign" wx:if="{{item.signTypeLabel}}">{{item.signTypeLabel}}</view>
      </view>

      <view class="time" wx:if="{{item.startTimeText}}">开始时间：{{item.startTimeText}}</view>

      <view class="support support-ok" wx:if="{{item.isSupported}}">
        已接入该签到类型，可以直接进入签到页
      </view>
      <view class="support support-no" wx:else>
        {{item.supportReason || '该活动类型一期暂不支持'}}
      </view>

      <button
        class="action {{item.isSupported ? 'primary' : 'secondary'}}"
        bindtap="openActivity"
        data-item="{{item}}"
      >
        {{item.isSupported ? '去签到' : '查看提示'}}
      </button>
    </view>
  </view>
</view>
