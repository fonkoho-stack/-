/* pages/schedule/schedule.wxss */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #FFFFFF; /* 匹配截图极简纯白底 */
  overflow: hidden;
}

/* --- Top Bar Switcher --- */
.top-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 40rpx 10rpx 40rpx;
  background-color: #FFFFFF;
}

.segment-control {
  display: flex;
  width: 100%;
  background: #F2F2F7;
  border-radius: 50rpx;
  padding: 6rpx;
}

.segment-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #8E8E93;
  padding: 16rpx 0;
  border-radius: 44rpx;
  transition: all 0.2s;
}

.segment-item.active {
  background: #FFFFFF;
  color: #34C759;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

/* ==================== TODAY VIEW ==================== */
.today-view {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
  padding: 30rpx 40rpx 80rpx 40rpx;
}

.today-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.today-title {
  font-size: 52rpx; /* 更大的日期字体 */
  font-weight: 800;
  color: #333333;
  letter-spacing: 0rpx;
  margin-right: 24rpx;
}

.today-tag {
  background: #E8F8F5;
  color: #34C759;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
}

/* Hero Card (Active) */
.hero-card {
  /* 灵动渐变背景 */
  background: linear-gradient(135deg, #34C759 0%, #2DBB54 100%);
  border-radius: 36rpx;
  padding: 40rpx 40rpx 40rpx 40rpx; /* 增加底部内边距至 40rpx，预留更多呼吸空间 */
  position: relative;
  overflow: hidden;
  margin-bottom: 60rpx;
  color: #fff;
  box-shadow: 0 20rpx 40rpx rgba(52,199,89,0.25);
}

.hero-bg-circle {
  position: absolute;
  right: -80rpx;
  top: -80rpx;
  width: 360rpx;
  height: 360rpx;
  background: rgba(255, 255, 255, 0.15); /* 使用高通透白光 */
  border-radius: 50%;
  z-index: 1;
}

.hero-tag {
  display: inline-block;
  background: rgba(255,255,255,0.25);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  margin-bottom: 30rpx;
  position: relative;
  z-index: 2;
}

.hero-course {
  font-size: 56rpx;
  font-weight: 800;
  margin-bottom: 30rpx;
  position: relative;
  z-index: 2;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1); /* 增加微妙立体感 */
}

.hero-meta {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: 400;
  opacity: 0.95;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 2;
}

.hero-meta .icon { margin-right: 12rpx; font-size: 30rpx; opacity: 1; }

.hero-btn {
  background: #ffffff;
  color: #34C759;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  padding: 26rpx;
  border-radius: 50rpx;
  margin-top: 40rpx; /* 稍微减小上边距至 40rpx，更紧凑有力 */
  position: relative;
  z-index: 2;
}

/* Hero Card (Empty - Rest Time) */
.empty-hero {
  /* 恢复浅色区分设计 */
  background: #F2F2F7;
  color: #1C1C1E; /* 极致黑，确保文字清晰可见 */
  box-shadow: none;
  border: 1rpx solid rgba(0,0,0,0.05); /* 增加极细边框，增强质感 */
}

.hero-bg-icon {
  position: absolute;
  right: 20rpx;
  bottom: -20rpx;
  font-size: 160rpx;
  opacity: 0.1; /* 极淡的背景装饰 */
  transform: rotate(15deg);
  z-index: 1;
}

.empty-hero .hero-tag { 
  background: rgba(0,0,0,0.05); 
  color: #636366; /* 增强标签对比度 */
}
.empty-hero .hero-course {
  color: #1C1C1E;
  text-shadow: none;
  font-size: 48rpx; /* 休息卡展示稍小一点点 */
}
.empty-hero .hero-meta {
  color: #8E8E93; /* 增强辅助文字对比度 */
}

/* Timeline Section */
.timeline-section {
  display: flex;
  flex-direction: column;
  margin-top: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 40rpx;
}

.timeline-item {
  display: flex;
  flex-direction: row;
  min-height: 180rpx;
}

.time-col {
  width: 100rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  padding-top: 10rpx;
}

.t-start {
  font-size: 34rpx;
  font-weight: 800;
  color: #333333;
  margin-bottom: 6rpx;
}

.t-dur {
  font-size: 20rpx;
  color: #C7C7CC; /* 极浅灰 */
}

.line-col {
  width: 60rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #E5E5EA;
  border-radius: 50%;
  margin-top: 24rpx;
}

.line {
  width: 2rpx;
  flex: 1;
  background-color: #F2F2F7; /* 极淡线条 */
  margin-top: 10rpx;
}

.card-col {
  flex: 1;
  background: #F8F9FA; /* 卡片灰底，配合纯白页底 */
  border-radius: 24rpx;
  padding: 30rpx 36rpx;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  box-shadow: none; /* 移除阴影，极致扁平 */
}

.c-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.c-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  line-height: 1.4;
  flex: 1;
}

.c-status {
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  margin-left: 20rpx;
  background: #E5E5EA;
  color: #8E8E93;
}

.c-status.active {
  background: rgba(52, 199, 89, 0.1);
  color: #34C759;
}

.c-footer {
  display: flex;
  align-items: center;
}

.c-loc {
  font-size: 24rpx;
  color: #999999;
}

/* ==================== WEEK VIEW ==================== */
.week-view {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* --- Pager Header --- */
.pager-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 40rpx 30rpx 40rpx;
  background-color: #FFFFFF;
  position: relative;
}

.week-pager {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.pager-btn {
  font-size: 24rpx;
  color: #999999;
  font-weight: 400;
  background: #F8F9FA;
  padding: 12rpx 28rpx;
  border-radius: 12rpx;
}

.pager-btn.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.pager-current {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.week-num {
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: 0rpx;
}

.reminder-badge {
  position: absolute;
  right: 40rpx;
  display: flex;
  align-items: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #333333;
}

.reminder-badge .icon {
  font-size: 32rpx;
  margin-right: 6rpx;
}

/* --- Hint --- */
.grid-hint {
  text-align: center;
  font-size: 20rpx;
  color: #999999;
  padding-bottom: 20rpx;
  background-color: #FFFFFF;
}

/* ==================== Grid View ==================== */
.grid-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  background-color: #FFFFFF;
  border-top-left-radius: 30rpx;
  border-top-right-radius: 30rpx;
  overflow: hidden;
}

.grid-scroll-area {
  flex: 1;
  width: 100vw;
  height: 100%;
}

.grid-table {
  display: flex;
  flex-direction: column;
  min-width: 100%;
  width: max-content;
}

.grid-header-row {
  display: flex;
  height: 80rpx;
  border-bottom: 1rpx solid #F8F9FA;
  background-color: rgba(255,255,255,0.95);
  backdrop-filter: blur(10px);
  position: sticky;
  top: 0;
  z-index: 15;
}

.grid-corner { 
  width: 70rpx; 
  flex-shrink: 0;
  border-right: 1rpx solid #F8F9FA; 
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #999999;
  font-weight: 500;
  position: sticky;
  left: 0;
  background-color: rgba(255,255,255,0.95);
  backdrop-filter: blur(10px);
  z-index: 20;
}

.day-hd {
  width: 130rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999999;
  font-weight: 500;
}

.day-hd.today-hd { 
  color: #34C759; 
  font-weight: 800; 
}

.grid-body-row {
  display: flex;
  position: relative;
}

.period-col {
  width: 70rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  border-right: 1rpx solid #F8F9FA;
  background-color: rgba(255,255,255,0.95);
  position: sticky;
  left: 0;
  z-index: 10;
}

.period-num {
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #999999;
  font-weight: 500;
}

.events-canvas {
  width: 910rpx; /* 130rpx * 7 days */
  position: relative;
  display: grid;
  grid-template-columns: repeat(7, 130rpx);
  grid-template-rows: repeat(12, 180rpx);
  z-index: 5;
}

/* Background Lines */
.grid-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  z-index: 0;
  pointer-events: none;
}
.bg-row {
  height: 180rpx;
  box-sizing: border-box;
  border-bottom: 1rpx dashed rgba(0,0,0,0.05);
}

.grid-empty-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: rgba(255,255,255,0.6);
  z-index: 5;
  pointer-events: none;
}
.grid-empty-overlay .empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.8;
}

/* Event Cards */
.event-card {
  margin: 4rpx;
  border-radius: 12rpx;
  padding: 10rpx;
  display: flex;
  flex-direction: column;
  color: rgba(255,255,255,0.95);
  overflow: hidden;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05); /* 保留极轻微底透阴影以维持立体感 */
}

.card-title { 
  font-size: 20rpx; /* 恢复紧凑高密度主标题 */
  font-weight: 800; 
  line-height: 1.25; 
  margin-bottom: 6rpx; 
  color: #fff;
  display: -webkit-box; 
  -webkit-line-clamp: 3; 
  -webkit-box-orient: vertical; 
  text-overflow: ellipsis;
  overflow: hidden; 
}

.card-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.meta-row {
  display: flex;
  align-items: flex-start;
  font-size: 16rpx; /* 恢复16rpx高精密辅助信息 */
  font-weight: 600;
  opacity: 1;
  line-height: 1.2;
}

.meta-icon {
  margin-right: 4rpx;
  font-size: 18rpx;
  opacity: 0.9;
}

.truncate-text {
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 完美匹配截图的幻彩渐变背景 (iOS 轻质感) */
.grad-0 { background: linear-gradient(135deg, #FF9A9E 0%, #FECFEF 100%); } /* Pink */
.grad-1 { background: linear-gradient(135deg, #84FAB0 0%, #8FD3F4 100%); } /* Green-Blue */
.grad-2 { background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%); } /* Purple-Pink */
.grad-3 { background: linear-gradient(135deg, #f6d365 0%, #fda085 100%); } /* Orange */
.grad-4 { background: linear-gradient(135deg, #E0C3FC 0%, #8EC5FC 100%); } /* Blue-Purple */
.grad-5 { background: linear-gradient(135deg, #accbee 0%, #e7f0fd 100%); } /* Light Blue */

/* Bottom Sheet */
.overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  backdrop-filter: blur(4px);
  z-index: 999;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s cubic-bezier(0.19, 1, 0.22, 1);
}
.overlay.show { visibility: visible; opacity: 1; }

.bottom-sheet {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-top-left-radius: 30rpx;
  border-top-right-radius: 30rpx;
  padding: 30rpx 40rpx 80rpx 40rpx;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.19, 1, 0.22, 1);
  z-index: 1000;
}
.bottom-sheet.show { transform: translateY(0); }

.sheet-drag-handle { width: 80rpx; height: 10rpx; background: #E5E5EA; border-radius: 5rpx; margin: 0 auto 40rpx auto; }
.sheet-header { margin-bottom: 40rpx; }
.sheet-title { font-size: 34rpx; font-weight: 700; color: #333333; line-height: 1.4; }

.detail-row { display: flex; align-items: flex-start; margin-bottom: 24rpx; font-size: 28rpx; color: #333333; font-weight: 400;}
.detail-row .icon { margin-right: 20rpx; font-size: 30rpx; opacity: 0.8; }

.evidence-box { background: #F8F9FA; border-radius: 12rpx; padding: 24rpx; margin-top: 30rpx; }
.evidence-title { font-size: 24rpx; font-weight: 600; color: #999999; margin-bottom: 12rpx; display: block; }
.evidence-content { font-size: 22rpx; color: #999999; line-height: 1.5; word-break: break-all; }

.sheet-footer { margin-top: 40rpx; text-align: center; }
.btn-delete { background: rgba(255,59,48,0.06); color: #FF3B30; border-radius: 12rpx; font-size: 30rpx; font-weight: 500; }
.btn-delete::after { border: none; }

/* ==================== Empty State (No Data) ==================== */
.empty-state {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.empty-state-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 80rpx 60rpx;
  background: #ffffff;
  border-radius: 32rpx;
  width: 100%;
}

.empty-state-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.empty-state-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 16rpx;
}

.empty-state-desc {
  font-size: 26rpx;
  color: #999999;
  line-height: 1.6;
  margin-bottom: 50rpx;
}

.empty-state-btn {
  background: #34C759;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 80rpx;
  border-radius: 50rpx;
  box-shadow: 0 10rpx 30rpx rgba(52, 199, 89, 0.2);
}
