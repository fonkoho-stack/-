/* pages/settings/settings.wxss */
.page {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding: 40rpx 40rpx 100rpx 40rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  margin-bottom: 50rpx;
  padding-top: 20rpx;
}

.title {
  font-size: 52rpx;
  font-weight: 800;
  color: #333333;
  letter-spacing: -2rpx;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999999;
  font-weight: 400;
}

.settings-list {
  display: flex;
  flex-direction: column;
}

/* Group Styles */
.group-title {
  font-size: 26rpx;
  font-weight: 400;
  color: #999999;
  margin-left: 30rpx;
  margin-bottom: 20rpx;
}

.group-card {
  background-color: var(--bg-card);
  border-radius: 24rpx;
  margin-bottom: 50rpx;
  overflow: hidden; /* No box-shadow! */
}

/* Cell Styles */
.cell {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 40rpx;
  border-bottom: 1rpx solid #F8F8F8;
  background-color: #fff;
  transition: background-color 0.2s;
}

.cell:active {
  background-color: #FAFAFA;
}

.border-none {
  border-bottom: none;
}

.cell-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.cell-label-col {
  display: flex;
  flex-direction: column;
}

.cell-sub {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.cell-value-wrap {
  display: flex;
  align-items: center;
}

.cell-value {
  font-size: 28rpx;
  color: #999999;
}

.badge-green {
  background: #E8F8F5;
  color: #34C759;
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 4rpx solid var(--text-sub-light);
  border-right: 4rpx solid var(--text-sub-light);
  transform: rotate(45deg);
  margin-left: 16rpx;
  margin-right: 8rpx;
}

/* Switches */
switch {
  transform: scale(0.9);
  margin-right: -10rpx; /* Align visual optical margin */
}

/* Danger Cell */
.danger-cell {
  justify-content: center;
}

.danger-text {
  color: #FF3B30;
  font-weight: 600;
}
